!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn-integrity
*.tgz

# Build output
dist/
dist-ssr/

# Vite, TypeScript, and Vitest caches
.vite/
.vite-node/
.vitest/
.vitest-dump/
*.tsbuildinfo
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.cache/
.eslintcache
.stylelintcache

# Test and coverage artifacts
coverage/
.nyc_output/
*.lcov
playwright-report/
blob-report/
test-results/
.local-browsers/
.playwright/
playwright/.cache/
playwright/.auth/

# Logs, profiles, and runtime data
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.cpuprofile
*.heapprofile
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
pids/
*.pid
*.pid.lock
*.seed

# Local environment files
.env
.env.*
!.env.example
!.env.*.example
*.local

# Temporary files
.tmp/
.temp/

# Editors and IDEs
.vscode/*
!.vscode/extensions.json
.idea/
.vs/
.history/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# Operating-system metadata
